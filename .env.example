# ULTRON environment variables.
# Copy this file to .env and fill in real keys for local dev.
# For Railway / other PaaS: paste these into the dashboard's env-var UI.

# ── Required: LLM providers ────────────────────────────────────────────
# The app uses tiered routing (tier1 → tier2 → tier3 fallback). All
# three providers below are expected. If any key is missing the driver
# falls back to the next tier, so partial keys work in a degraded way.

ANTHROPIC_API_KEY=          # Claude Haiku + Sonnet (tier 2 + tier 3)
CEREBRAS_API_KEY=           # Cerebras Llama 3.1 8B (tier 1, fastest)

# ── Required: speech I/O ───────────────────────────────────────────────
# Deepgram handles BOTH TTS (Aura voices) and STT (Nova-3 streaming).
# Without this key the server boots but voice I/O is disabled unless
# the local Piper fallback is present (bin/piper/ + voices/*.onnx,
# which are gitignored — not present on hosted deploys by default).

DEEPGRAM_API_KEY=

# ── Optional: web search ───────────────────────────────────────────────
# Used by the brave_web_search tool. Without it the tool returns an
# "unavailable" message; nothing else breaks.

BRAVE_API_KEY=

# ── Optional: Google Gemini (currently unused by default config) ───────
GOOGLE_API_KEY=

# ── Database (only if memory.backend = postgresql in configs/app.yaml) ─
# Default config uses SQLite on local disk, so this is normally unset.
# On Railway: attach the Postgres plugin and it will inject this for
# you. External Postgres works too — any libpq-compatible URL.

# DATABASE_URL=postgresql://user:pass@host:5432/mother_db

# ── Optional: Vision (MQTT broker for Jetson vision feed) ──────────────
# If unset, vision is disabled gracefully. Ultron just can't "see."

# MQTT_HOST=localhost
# MQTT_PORT=1883
# JETSON_VISION_TOPIC=vision/events

# ── Optional: wake word tuning (browser-side uses its own config) ──────
# WAKE_WORD_MODEL_PATH=dashboard/public/models/hey_jarvis_v0.1.onnx
# WAKE_WORD_SENSITIVITY=0.5

# ── Optional: TTS voice tuning (if using Chatterbox provider) ──────────
# ULTRON_VOICE_PATH=tts/voice_profiles/ultron_reference.wav
# TTS_EXAGGERATION=0.45
# TTS_CFG_WEIGHT=0.5

# ── Frontend (Vite reads these at dashboard/ build time, not here) ─────
# Kept for reference — these go in dashboard/.env, not the backend's.
# VITE_WS_URL=wss://your-app.up.railway.app/ws/voice
# VITE_API_URL=https://your-app.up.railway.app

# ── PaaS-injected (don't set manually) ─────────────────────────────────
# PORT     — Railway/Heroku/Render/Fly set this; the app honours it.
# HOST     — defaults to 0.0.0.0 so the container is reachable.
